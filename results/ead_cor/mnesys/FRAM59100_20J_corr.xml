            <repository>Archives de la ville de Roubaix</repository><unittitle>Archives personnelles de Mme Pauline Kubas et M. Joseph Gralak.</unittitle><unitid identifier="20J/1-20J/41">20J1-41</unitid><unitdate normal="1919-01-01/1961-12-31" type="inclusive">1919-1961</unitdate><langmaterial>Français, polonais, allemand.</langmaterial>
            
            
            
            
            
